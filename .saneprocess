# SaneProcess compliance manifest
# Metadata read by Scripts/qa.rb and the (maintainer-only) SaneProcess tooling.
name: SaneBar
type: macos_app
scheme: SaneBar
project: SaneBar.xcodeproj
bundle_id: com.sanebar.app

build:
  xcodegen: true

release:
  team_id: M78L6FXD48
  signing_identity: "Developer ID Application"
  dist_host: dist.sanebar.com
  site_host: sanebar.com
  r2_bucket: sanebar-downloads
  use_sparkle: true
  min_system_version: "14.0"

commands:
  verify: ./Scripts/SaneMaster.rb verify
  test_mode: ./Scripts/SaneMaster.rb tm
  lint: ./Scripts/SaneMaster.rb lint
  clean: ./Scripts/SaneMaster.rb clean
  launch: ./Scripts/SaneMaster.rb launch
  logs: ./Scripts/SaneMaster.rb logs

docs:
  - README.md
  - DEVELOPMENT.md
  - ARCHITECTURE.md

website: true
website_domain: sanebar.com

# Distribution lanes beyond direct download are retired (sunset, June 2026).
setapp:
  enabled: false
  scheme: SaneBarSetapp
  configuration: Release-Setapp
  bundle_id: com.sanebar.app-setapp
  public_key_path: Setapp/setappPublicKey.pem

appstore:
  enabled: false
  # SaneBar never shipped through the Mac App Store; the lane is dormant.
