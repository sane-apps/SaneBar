# SaneProcess compliance manifest
name: SaneBar
type: macos_app
scheme: SaneBar
project: SaneBar.xcodeproj
bundle_id: com.sanebar.app

build:
  xcodegen: true

release:
  team_id: M78L6FXD48
  signing_identity: "Developer ID Application"
  dist_host: dist.sanebar.com
  site_host: sanebar.com
  r2_bucket: sanebar-downloads
  use_sparkle: true
  min_system_version: "15.0"
  dmg:
    volume_icon: Resources/DMGIcon.icns
    file_icon: Resources/DMGIcon.icns
    window_size: "800 400"
    app_icon_pos: "200 185"
    drop_pos: "600 185"

commands:
  verify: ./scripts/SaneMaster.rb verify
  test_mode: ./scripts/SaneMaster.rb tm
  lint: ./scripts/SaneMaster.rb lint
  clean: ./scripts/SaneMaster.rb clean
  launch: ./scripts/SaneMaster.rb launch
  logs: ./scripts/SaneMaster.rb logs

docs:
  - CLAUDE.md
  - README.md
  - DEVELOPMENT.md
  - ARCHITECTURE.md
  - SESSION_HANDOFF.md

mcps:
  - apple-docs
  - context7
  - github
  - XcodeBuildMCP
  - macos-automator

website: true
website_domain: sanebar.com

appstore:
  enabled: false
  # Current strategy: direct-download only.
  # Do not route the current full-featured build through App Store release automation.
  # App Store metadata below is retained only as dormant reference and is not an active lane.
  app_id: "6759464256"
  product_id: "com.sanebar.app.pro.unlock"
  configuration: Release-AppStore
  platforms: [macos]
  category: public.app-category.utilities
  age_rating: "4+"
  privacy_policy_url: "https://sanebar.com/privacy"
  support_url: "https://sanebar.com/support"
  marketing_url: "https://sanebar.com"
  metadata:
    macos:
      subtitle: "Hide Menu Bar Clutter"
      promotional_text: "Hide noisy menu bar icons, keep essentials visible, and reveal hidden apps instantly with hotkeys, hover, or click."
      description: >-
        SaneBar keeps your menu bar clean without losing access to the apps you rely on.
        Hide rarely used icons, keep critical icons visible, and reveal everything instantly when you need it.
        Works with notch Macs, supports keyboard-first control, and keeps all processing on-device.
      keywords: "menu bar,hide icons,status bar,productivity,notch,mac utility,focus,desktop"
      whats_new: "Improved icon move reliability, faster refresh, and stronger stability around launch and permissions."
      marketing_url: "https://sanebar.com"
  review_notes: "SaneBar's current public strategy is direct download only. The Mac App Store lane is intentionally inactive for the current full-featured build and should not be submitted from this repo state. If an App Store-safe variant is revisited later, re-validate sandbox-safe behavior, pricing, and reviewer guidance from scratch."
  accessibility_declarations:
    publish: true
    mac:
      supports_dark_interface: true
  screenshots:
    macos: marketing/appstore-images/*.png
  entitlements: SaneBar/SaneBar-AppStore.entitlements
  build_flags:
    - 'INFOPLIST_KEY_SUFeedURL='
    - 'INFOPLIST_KEY_SUEnableAutomaticChecks='
    - 'INFOPLIST_KEY_SUPublicEDKey='
  strip_frameworks:
    - Sparkle.framework
  contact:
    name: "Stephan Joseph"
    phone: "+17277589785"
    email: "hi@saneapps.com"
